# Required for every deployment
GOOGLE_SHEET_ID=
ADMIN_PASSWORD=
AUTH_SECRET=

# Recommended OAuth-only deployment. With GOOGLE_REFRESH_TOKEN set,
# public kiosk checkout and password-protected admin writes work without Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional fallback: legacy service-account deployment.
# Used only when GOOGLE_REFRESH_TOKEN is not set.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
