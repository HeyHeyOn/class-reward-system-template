# Google Sheets settings
# Copy to .env.local and fill these values.
GOOGLE_SHEET_ID=

# Recommended for deployment: Google service account credentials.
# Share the spreadsheet with this service account email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional kiosk/admin protection for MVP
KIOSK_ADMIN_PIN=1234
