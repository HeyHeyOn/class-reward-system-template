# 학급 보상 시스템 운영 앱 Vercel 환경변수 예시
# 선생님별 Vercel 프로젝트에서 Production 환경변수로 입력합니다.

# 생성기가 만든 Google Sheets ID
GOOGLE_SHEET_ID=

# 관리자 페이지(/admin/login) 접속 비밀번호
ADMIN_PASSWORD=

# 로그인/쿠키 암호화를 위한 긴 무작위 문자열
# 예: 32자 이상의 영문/숫자/기호 조합
AUTH_SECRET=

# Google Sheets 접근 방식 A: OAuth refresh token
# 운영 앱이 Google Sheets를 직접 읽고 쓰려면 아래 3개 값이 필요합니다.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Sheets 접근 방식 B: 서비스 계정 fallback
# OAuth refresh token을 쓰지 않는 경우에만 사용합니다.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# 생성기 전용 배포에서만 사용합니다. 일반 선생님 운영 앱에서는 비워둡니다.
NEXT_PUBLIC_CLASS_STORE_DEPLOYMENT=
NEXT_PUBLIC_CLASS_STORE_TEMPLATE_REPO=
